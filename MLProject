name: Financial_News_Analysis
conda_env: conda.yaml

entry_points:
  topic_prep_data:
    command: "python3 src/topic/topic_data_prep.py"
  topic_tokenize_data:
    command: "python3 src/topic/topic_data_tokenize.py"
  sent_clean_data:
    command: "python3 src/sentiment/sent_data_clean.py"
  sent_split_data:
    command: "python3 src/sentiment/sent_data_split.py"
  sent_tokenize_data:
    command: "python3 src/sentiment/sent_data_tokenize.py"
  mail:
    command: "python3 src/utils/mail.py"
  main:
    parameters:
      lr: {type: float, default: 0.0001}
      epochs: {type: int, default: 15}
      wgt_decay: {type: float, default: 0.01}
    command: "python3 src/sentiment/sent_train.py --lr {lr} --epochs {epochs} --wgt_decay {wgt_decay}"
