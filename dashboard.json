{
  "title": "Financial News Analysis v3",
  "description": "Dashboard for Financial News Analysis AI application metrics and Hardware metrics",
  "tags": ["finance", "ai", "image"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "stat",
      "title": "Application Health",
      "description": "Promotheus for Application is Up",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"financial-analysis\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Inference Latency",
      "description": "Calculates the average inference latency (seconds) per image",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (mode) (rate(app_inference_latency_seconds_sum[1m])) / sum by (mode) (rate(app_inference_latency_seconds_count[1m]))",
          "legendFormat": "{{mode}} mode latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "axisLabel": "Latency (sec)",
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "timeseries",
      "title": "System CPU Utilization",
      "description": "Tracks host CPU usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "Total CPU Usage %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "axisLabel": "Utilization (%)",
            "axisPlacement": "left",
            "drawStyle": "line",
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "timeseries",
      "title": "System & App Memory Utilization",
      "description": "Monitors available host memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Total Host RAM Used",
          "refId": "A"
        },
        {
          "expr": "app_model_memory_bytes",
          "legendFormat": "App RSS Memory (Model)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "axisLabel": "Memory (Bytes)",
            "axisPlacement": "left",
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "table",
      "title": "Recent Alert Events",
      "description": "Displays all active alerts handled by Alertmanager",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "ALERTS",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Requests",
      "description": "Number of images currently to be processed",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(app_active_requests_current)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "value" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request vs. Exception Rate",
      "description": "Total incoming requests vs Exceptions",
      "gridPos": { "h": 6, "w": 10, "x": 4, "y": 14 },
      "targets": [
        {
          "expr": "sum by (mode) (increase(app_total_requests_total[1m]))",
          "legendFormat": "Requests ({{mode}})",
          "refId": "A"
        },
        {
          "expr": "sum by (mode, error_type) (increase(app_total_errors_total[1m]))",
          "legendFormat": "Errors ({{mode}} - {{error_type}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "axisLabel": "Count / Minute",
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*Errors.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "timeseries",
      "title": "Disk Read",
      "description": "Disk Read Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[1m])",
          "legendFormat": "Read ({{device}})",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[1m])",
          "legendFormat": "Written ({{device}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "axisLabel": "Count / Minute",
            "axisPlacement": "left",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Context Switch",
      "description": "Context Switching per sec in CPU",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "rate(node_context_switches_total[1m])",
          "legendFormat": "Switches / sec",
          "refId": "A"
        },
        {
          "expr": "rate(node_intr_total[1m])",
          "legendFormat": "Interrupts / sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "axisLabel": "Operations / Second",
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "type": "timeseries",
      "title": "Data Drift",
      "description": "Rate of Change of Data Distribution seen by the Topic Model",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (rate(topic_model_input_classes_total[5m]))",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "timeseries",
      "title": "Data Drift",
      "description": "Rate of Change of Data Distribution seen by the Sentiment model",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (rate(sent_model_input_classes_total[5m]))",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "barchart",
      "title": "Current Topic Data Distribution",
      "description": "Cumulative distribution of the data among topic classes seen till now",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (topic_model_input_classes_total)",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showValue": "never",
        "groupWidth": 0.6,
        "barWidth": 0.9,
        "barRadius": 0,
        "stacking": "none",
        "tooltipOptions": { "mode": "single" }
      }
    },
    {
      "type": "piechart",
      "title": "Current Topic Data Distribution (Pie Chart)",
      "description": "Cumulative distribution of the data among topic classes seen till now",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (topic_model_input_classes_total)",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Current Sentiment Data Distribution",
      "description": "Cumulative distribution of the data among sentiment classes seen till now",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (sent_model_input_classes_total)",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showValue": "never",
        "groupWidth": 0.6,
        "barWidth": 0.9,
        "barRadius": 0,
        "stacking": "none",
        "tooltipOptions": { "mode": "single" }
      }
    },
    {
      "type": "piechart",
      "title": "Current Sentiment Data Distribution (Pie Chart)",
      "description": "Cumulative distribution of the data among sentiment classes seen till now",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (sent_model_input_classes_total)",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Model Reliability",
      "description": "How reliable are each of the models",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "(sum by (model_name) (rate(model_inference_status_total{status!=\"success\"}[5m]))/sum by (model_name) (rate(model_inference_status_total[5m]))) * 100",
          "legendFormat": "{{model_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "type": "barchart",
      "title": "Topic Data Drift Distribution",
      "description": "Drift in the topic class distribution",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (rate(topic_model_input_classes_total[1h])) / scalar(sum(rate(topic_model_input_classes_total[1h])))",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        },
        {
          "expr": "topic_model_baseline_class_distribution",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showValue": "never",
        "groupWidth": 0.6,
        "barWidth": 0.9,
        "barRadius": 0,
        "stacking": "none",
        "tooltipOptions": { "mode": "single" }
      }
    },
    {
      "type": "barchart",
      "title": "Sentiment Data Drift Distribution",
      "description": "Drift in the sentiment class distribution",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (class_name) (rate(sent_model_input_classes_total[1h])) / scalar(sum(rate(sent_model_input_classes_total[1h])))",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        },
        {
          "expr": "sent_model_baseline_class_distribution",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "showValue": "never",
        "groupWidth": 0.6,
        "barWidth": 0.9,
        "barRadius": 0,
        "stacking": "none",
        "tooltipOptions": { "mode": "single" }
      }
    },
    {
      "type": "stat",
      "title": "Overall Topic PSI",
      "description": "PSI across all classes in Topic Modelling",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum((( (sum by (class_name) (rate(topic_model_input_classes_total[1h])) / scalar(sum(rate(topic_model_input_classes_total[1h])))) + 1e-5 )- ( model_baseline_class_dist + 1e-5 )) * ln(( (sum by (class_name) (rate(topic_model_input_classes_total[1h])) / scalar(sum(rate(topic_model_input_classes_total[1h])))) + 1e-5 )/ ( model_baseline_class_dist + 1e-5 )))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0.1,
                "result": { "text": "MILD", "color": "green" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.1,
                "to": 0.2,
                "result": { "text": "MODERATE", "color": "yellow" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.2,
                "to": 100,
                "result": { "text": "SEVERE", "color": "red" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Overall Sentiment PSI",
      "description": "PSI across all classes in Sentiment Analysis",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum((( (sum by (class_name) (rate(sent_model_input_classes_total[1h])) / scalar(sum(rate(sent_model_input_classes_total[1h])))) + 1e-5 )- ( model_baseline_class_distribution + 1e-5 )) * ln(( (sum by (class_name) (rate(topic_model_input_classes_total[1h])) / scalar(sum(rate(topic_model_input_classes_total[1h])))) + 1e-5 )/ ( sent_model_baseline_data_dist + 1e-5 )))",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0.1,
                "result": { "text": "MILD", "color": "green" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.1,
                "to": 0.2,
                "result": { "text": "MODERATE", "color": "yellow" }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.2,
                "to": 100,
                "result": { "text": "SEVERE", "color": "red" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Topic Model Accuracy Decay",
      "description": "Calculates the topic model accuracy decay with time",
      "gridPos": { "h": 6, "w": 10, "x": 14, "y": 0 },
      "targets": [
        {
          "expr": "sum by (model_name) (rate(model_prediction_correctness_total{status=\"correct\"}[24h]))/sum by (model_name) (rate(model_feedback_received_total[24h]))",
          "legendFormat": "{{mode_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "axisLabel": "Latency (sec)",
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    }
  ],
  "templating": {
    "list": []
  }
}
